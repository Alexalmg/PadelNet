# Copia este fichero a .env y rellena los valores

# Base de datos (Neon: https://neon.tech → copia la connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# O si usas variables separadas:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=padelnet
DB_USER=padelnet_user
DB_PASSWORD=cambia_esto

# JWT - genera strings aleatorios largos (ej: openssl rand -hex 32)
JWT_SECRET=cambia_esto_por_algo_secreto_largo_y_aleatorio
JWT_REFRESH_SECRET=otro_secreto_diferente_para_el_refresh_token
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=production

# CORS - pon la URL de tu app en producción
CORS_ORIGIN=https://tu-app.onrender.com
